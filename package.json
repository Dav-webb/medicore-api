{
  "name": "medicore-api",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "MediCore AI — Backend API Server",
  "main": "src/index.js",
  "scripts": {
    "start":     "node src/index.js",
    "dev":       "nodemon src/index.js",
    "db:init":   "node src/db/init.js",
    "db:migrate":"node src/db/migrate.js",
    "db:seed":   "node src/db/seed.js"
  },
  "dependencies": {
    "express":             "^4.19.2",
    "pg":                  "^8.12.0",
    "bcryptjs":            "^2.4.3",
    "jsonwebtoken":        "^9.0.2",
    "express-validator":   "^7.1.0",
    "cors":                "^2.8.5",
    "helmet":              "^7.1.0",
    "express-rate-limit":  "^7.3.1",
    "dotenv":              "^16.4.5",
    "morgan":              "^1.10.0",
    "uuid":                "^10.0.0",
    "cookie-parser":       "^1.4.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
